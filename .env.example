# Dev: leave unset to use Vite proxy (/api -> backend, see vite.config.ts).
# Production or direct backend: full origin, CORS must allow this app + credentials.
# VITE_API_BASE_URL=http://localhost:6969

# Optional: proxy target when using default /api (default http://localhost:6969)
# VITE_PROXY_TARGET=http://localhost:6969
